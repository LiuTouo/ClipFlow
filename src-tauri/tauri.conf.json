{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipFlow",
  "identifier": "com.clipflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https://api.github.com",
        "img-src": "'self' data:",
        "style-src": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "(https://|[A-Za-z]:[\\\\/]).*"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5QjAzOEE4RUJCOTM4MjAKUldRZ09MbnJxRGl3Mlp3NTlQaVNtTmxJS1B1NjRtQ3JjdFlPaklzR2V6d0ZQQ1hoak1NSDdyWDIK",
      "endpoints": [
        "https://github.com/LiuTouo/ClipFlow/releases/latest/download/latest.json"
      ]
    }
  }
}
